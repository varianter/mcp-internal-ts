# Copy to .env for local development. Never commit .env.
#
# HOST: use 127.0.0.1 locally (AKS uses 0.0.0.0 via ConfigMap)
HOST=127.0.0.1
PORT=8080
MCP_PATH=/mcp

# Azure — populated automatically in AKS by the Workload Identity webhook.
# Locally, leave blank and use `az login` for any Azure calls.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Key Vault — set this locally to fetch secrets via DefaultAzureCredential (az login).
# In k8s this is left unset; secrets are injected as env vars via values.yaml instead.
KEYVAULT_URL=https://<your-keyvault-name>.vault.azure.net/

# FlowCase — required for the get-cv-for-consultant resource.
# FLOWCASE_ORG:     your FlowCase subdomain (e.g. "variant" → variant.flowcase.com)
# FLOWCASE_API_KEY: API token from FlowCase admin settings
#
# Will be populated in KeyVault (login to your user), or override manually here.
FLOWCASE_ORG=
FLOWCASE_API_KEY=

# GitHub — required for the github-app-exists and github-deploy-app tools.
# Create a fine-grained PAT at GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens:
#   Resource owner: varianter
#   Repository access: Only select → varianter/external-artifacts + varianter/vibe-artifacts
#   Permissions: Contents = Read and write; Metadata = Read (auto-granted)
#
# Will be populated in KeyVault (login to your user), or override manually here.
GITHUB_TOKEN=
