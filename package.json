{
  "name": "variant-internal-mcp-ts",
  "version": "0.1.0",
  "description": "Variant internal MCP server (TypeScript)",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector --transport http --server-url http://localhost:8080/mcp",
    "jam": "pnpm dlx @mcpjam/inspector@latest --config mcp.config.json --server variant-internal",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/keyvault-secrets": "4.11.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
